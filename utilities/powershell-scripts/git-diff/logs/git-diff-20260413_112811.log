+ */
+
+package com.mastercard.pgs.connectivity.acquirer.flow.scenarios;
+
+import com.mastercard.mpgs.acquiring.mctf.model.Interactions;
+import com.mastercard.pgs.connectivity.acquirer.elavon.message.MessageType;
+import com.mastercard.test.flow.builder.Deriver;
+import com.mastercard.test.flow.builder.mutable.MutableInteraction;
+
+import java.util.function.Consumer;
+
+import lombok.Getter;
+
+import static com.mastercard.mpgs.acquiring.flow.util.TestDataConstants.SERVICE_PROVIDER_TRANSACTION_PROCESSING_AUTHORIZATION_CODE;
+import static com.mastercard.mpgs.acquiring.flow.util.TestDataConstants.SERVICE_PROVIDER_TRANSACTION_PROCESSING_RESPONSE_CODE;
+import static com.mastercard.mpgs.acquiring.flow.util.TestDataConstants.SERVICE_PROVIDER_TRANSACTION_PROCESSING_RESPONSE_MESSAGE;
+import static com.mastercard.mpgs.acquiring.mctf.model.Interactions.rq;
+import static com.mastercard.mpgs.acquiring.mctf.model.Interactions.rs;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.ORDER_AUTHENTICATION_STATUS;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.ORDER_STATUS;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.ORDER_TOTAL_AUTHORIZED_AMOUNT;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.ORDER_TOTAL_CAPTURED_AMOUNT;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.ORDER_TOTAL_REFUNDED_AMOUNT;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.RESPONSE_GATEWAY_RECOMMENDATION;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.Fields.TRANSACTION_TYPE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_ADDITIONAL_AMOUNTS;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_AMOUNT;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_APPROVAL_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_CARD_ACCEPTOR;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_CARD_SCHEME_DATA;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_CONDITION_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_EXPIRY;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_MC_MPGID;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_NII;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_PAN;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_POS_ENTRY_MODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_PROCESSING_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_RRN_48_2;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_FIELD_RRN_48_4;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_AMOUNT;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_CARD_SCHEME_DATA_RESPONSE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_CONDITION_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_NII;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_PROCESSING_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_RRN;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.ACQ_VOID_STAN;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.AUTHORIZATION_CODE_VALUE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.CARD_ACCEPTOR;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.CARD_EXPIRY;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.DEFAULT_APPROVAL_CODE;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.MC_PAN;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.RESPONSE_CODE_SUCCESS;
+import static com.mastercard.pgs.connectivity.acquirer.flow.constant.TestConstants.RESPONSE_MESSAGE_APPROVED;
+import static com.mastercard.pgs.connectivity.acquirer.flow.msg.ElavonTestMessage.MESSAGE_TYPE;
+import static com.mastercard.test.flow.msg.AbstractMessage.DELETE;
+
+// Note: TRANSACTION_TYPE, STAN, and RRN in rq are set at the model level via
+// ElavonVoidTransactions#buildCommonVoidAuthRequestFields() ΓÇö scenario consumers apply overrides
+// only.
+
+/**
+ * Void AUTH scenarios for the Elavon Flow Test Framework. // Migrated from: Void.VOID_AUTH_SCENARIO
+ * ΓÇö TSPI, PAY, CAPTURE, REFUND excluded per rules v3.0.
+ */
+public enum VoidScenarios {
+
+	/**
+	 * VOID_AUTH ΓÇö ATF scenario {@code "VOID_AUTH CANCELLED 0.00 0.00 0.00"}. Mapped from
+	 * {@code Void.VOID_AUTH_SCENARIO} on {@code Base.AUTH}.
+	 */
+	VOID_AUTH ("Void for VOID_AUTH");
+
+	public final Consumer<Deriver> data;
+
+	@Getter
+	private final String description;
+
+	VoidScenarios( String description ) {
+		this.description = description;
+		this.data = flow -> flow
+		    .update( Interactions.CPC, buildVoidCpcConnectivityResponse() )
+		    .update( Interactions.CONNECTIVITY, buildVoidCpcConnectivityResponse() )
+		    // ACQUIRER ΓÇö ISO 8583 Void Authorization fields; not shared with CPC/CONNECTIVITY.
+		    .update( Interactions.ACQUIRER,
+		        rq(
+		            MESSAGE_TYPE, MessageType.VOID_AUTHORIZATION,
+		            ACQ_FIELD_PAN, MC_PAN,
+		            ACQ_FIELD_EXPIRY, CARD_EXPIRY,
+		            ACQ_FIELD_NII, ACQ_VOID_NII,
+		            ACQ_FIELD_CONDITION_CODE, ACQ_VOID_CONDITION_CODE,
+		            ACQ_FIELD_APPROVAL_CODE, DELETE,
+		            ACQ_FIELD_RRN_48_2, ACQ_VOID_STAN,
+		            ACQ_FIELD_RRN_48_4, ACQ_VOID_RRN,
+		            ACQ_FIELD_POS_ENTRY_MODE, DELETE,
+		            ACQ_FIELD_CARD_ACCEPTOR, CARD_ACCEPTOR,
+		            ACQ_FIELD_CARD_SCHEME_DATA, DELETE,
+		            ACQ_FIELD_MC_MPGID, DELETE ),
+		        rs(
+		            ACQ_FIELD_PAN, MC_PAN,
+		            MESSAGE_TYPE, MessageType.VOID_AUTHORIZATION_RESPONSE,
+		            ACQ_FIELD_PROCESSING_CODE, ACQ_VOID_PROCESSING_CODE,
+		            ACQ_FIELD_AMOUNT, ACQ_VOID_AMOUNT,
+		            ACQ_FIELD_APPROVAL_CODE, DEFAULT_APPROVAL_CODE,
+		            ACQ_FIELD_NII, ACQ_VOID_NII,
+		            ACQ_FIELD_CONDITION_CODE, ACQ_VOID_CONDITION_CODE,
+		            ACQ_FIELD_CARD_SCHEME_DATA, ACQ_VOID_CARD_SCHEME_DATA_RESPONSE,
+		            ACQ_FIELD_ADDITIONAL_AMOUNTS, DELETE ) );
+	}
+
+	/**
+	 * Shared CPC/CONNECTIVITY void-auth response: clears order totals and sets approval fields.
+	 *
+	 * @return {@link Consumer} applying the void-auth response fields to CPC or CONNECTIVITY
+	 */
+	private static Consumer<MutableInteraction> buildVoidCpcConnectivityResponse() {
+		return rs(
+		    ORDER_TOTAL_AUTHORIZED_AMOUNT, DELETE,
+		    ORDER_TOTAL_CAPTURED_AMOUNT, DELETE,
+		    ORDER_TOTAL_REFUNDED_AMOUNT, DELETE,
+		    ORDER_AUTHENTICATION_STATUS, DELETE,
+		    ORDER_STATUS, DELETE,
+		    TRANSACTION_TYPE, DELETE,
+		    RESPONSE_GATEWAY_RECOMMENDATION, DELETE,
+		    SERVICE_PROVIDER_TRANSACTION_PROCESSING_AUTHORIZATION_CODE, AUTHORIZATION_CODE_VALUE,
+		    SERVICE_PROVIDER_TRANSACTION_PROCESSING_RESPONSE_CODE, RESPONSE_CODE_SUCCESS,
+		    SERVICE_PROVIDER_TRANSACTION_PROCESSING_RESPONSE_MESSAGE, RESPONSE_MESSAGE_APPROVED );
+	}
+}
