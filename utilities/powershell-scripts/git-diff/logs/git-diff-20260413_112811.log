+run-generate-tree.bat
+
+:: Current directory with depth limit
+run-generate-tree.bat 3
+
+:: Specific repo path
+run-generate-tree.bat C:\path\to\repo
+
+:: Repo path with depth limit
+run-generate-tree.bat C:\path\to\repo 3
+
+:: Full specification
