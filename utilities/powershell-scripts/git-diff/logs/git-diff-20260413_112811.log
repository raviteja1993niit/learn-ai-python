+	/**
+	 * Builds a void authorization request message.
+	 * <p>
+	 * Uses {@link MessageType#VOID_AUTHORIZATION} so that the CONNECTIVITY layer request carries the
+	 * correct {@code RoutingHeader.Action} value that {@code Local.serviceUrl} needs to resolve the
+	 * void service endpoint.
+	 *
+	 * @return void authorization request message
+	 */
+	public static Message voidRequest() {
+		Consumer<ElavonMessage> VOID_REQ = AUTH_REQ.andThen(
+		    m -> m.setMessageType( MessageType.VOID_AUTHORIZATION )
+		        .body()
+		        .setSystemTrace( "654321" )
+		        .setLocalDateTime( "250524170515" )
+		        .setReconciliationDate( "250524" )
+		        .setReferenceNumber( "3448654321" ) );
+		return new ElavonTestMessage( VOID_REQ ).masking( Unpredictables.RNG,
+		    m -> m.replace( "11", STAN_NUMBER )
+		        .replace( "37", RRN ) );
+	}
+
+	/**
+	 * Builds a void authorization response message.
+	 *
+	 * @return void authorization response message
+	 */
+	public static Message voidResponse() {
+		Consumer<ElavonMessage> VOID_RES = AUTH_RES.andThen(
+		    m -> m.setMessageType( MessageType.VOID_AUTHORIZATION_RESPONSE )
+		        .body()
+		        .setSystemTrace( "654321" )
+		        .setLocalDateTime( "250524170515" )
+		        .setReconciliationDate( "250524" )
+		        .setReferenceNumber( "3448654321" ) );
+		return new ElavonTestMessage( VOID_RES ).masking( Unpredictables.RNG,
+		    m -> m.replace( "11", STAN_NUMBER )
+		        .replace( "37", RRN ) );
+	}
+
 	private static ElavonTestMessage getMaskedElavonTestMessage() {
 		return new ElavonTestMessage( AUTH_RES ).masking( Unpredictables.SYSTEM_CLOCK,
 		    m -> m.delete( "12", "28", FOURTY_EIGHT_THREE ) )
