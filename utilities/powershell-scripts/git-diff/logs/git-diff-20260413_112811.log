+import static com.mastercard.test.flow.util.Tags.set;
+import static com.mastercard.test.flow.util.Transmission.Type.REQUEST;
+import static com.mastercard.test.flow.util.Transmission.Type.RESPONSE;
+
+/**
+ * VOID_AUTH flows for the Elavon Flow Test Framework. Implements a two-transaction pattern:
+ * <ol>
+ * <li>Execute a normal base authorization transaction first.</li>
+ * <li>Execute a void authorization transaction with associated fields mapped from the auth
+ * response.</li>
+ * </ol>
+ * Migrated from: Void.transactions() ΓÇö PAY, CAPTURE, REFUND, UPDATE_AUTH, TSPI excluded per rules
+ * v3.0.
+ */
+public final class ElavonVoidTransactions extends EagerModel {
+
+	public static final String VOID_TAG = "authVoid";
+
+	public static final TaggedGroup MODEL_TAGS = new TaggedGroup( VOID_TAG );
+
+	// Matches ISO 8583 amount "000000002112" (21.12 in minor units).
+	private static final BigDecimal VOID_AUTH_AUTHORIZED_AMOUNT = new BigDecimal( "21.12" );
+
+	private final AuthFPAN authFPAN = new AuthFPAN();
+	private final AuthVoid authVoid = new AuthVoid( authFPAN );
+	private final Map<VoidScenarios, Flow> flowMap = new HashMap<>();
+
+	public ElavonVoidTransactions() {
+		super( MODEL_TAGS );
+
+		// Step 1: Create and cache auth flows for each void scenario.
+		final Stream<Flow> authFlows = Arrays.stream( VoidScenarios.values() )
+		    .map( this::createAuthFlowForVoidScenario );
+
+		// Step 2: Create void flows that depend on cached auth flows for field mapping.
+		final Stream<Flow> voidFlows = Arrays.stream( VoidScenarios.values() )
+		    .map( this::createVoidFlowForScenario );
+
+		// Flatten both auth and void flows into the model.
+		members( flatten( Stream.concat( authFlows, voidFlows ) ) );
+	}
+
+	/**
+	 * Creates a base authorization flow for a given void scenario. This flow is cached in
+	 * {@link #flowMap} for later reference during void flow creation.
+	 *
+	 * @param scenario the void scenario for which to build the base auth flow
+	 * @return the built auth {@link Flow}
+	 */
+	private Flow createAuthFlowForVoidScenario( VoidScenarios scenario ) {
+		Flow authFlow = Deriver.build( authFPAN.newAuth, getElavonAuthBaseInteraction(),
+		    flow -> {
+			    flow.meta( data -> data
+			        .trace( "Base Auth for " + scenario.getDescription() )
+			        .description( "Base Auth for " + scenario.getDescription() )
+			        .tags( set( "auth" ) ) );
+
+			    // Apply standard auth scenario fields (from VoidScenarios context).
+			    // For now, use minimal auth configuration; extend as needed per scenario requirements.
+		    } );
+
+		flowMap.put( scenario, authFlow );
+		return authFlow;
+	}
+
+	/**
+	 * Creates a void authorization flow deriving from {@code authVoid.authVoid_With_All_Fields}.
+	 * Applies associated authorization field mapping from the cached base auth flow.
+	 *
+	 * @param scenario the void scenario to build
+	 * @return the built void {@link Flow}
+	 */
+	private Flow createVoidFlowForScenario( VoidScenarios scenario ) {
+		return Deriver.build( authVoid.authVoid_With_All_Fields, getElavonVoidBaseInteraction(),
+		    flow -> {
+			    flow.meta( data -> data
+			        .trace( scenario.getDescription() )
+			        .description( scenario.getDescription() )
+			        .tags( set( VOID_TAG ) ) );
+
+			    // Build void submission-level request fields (TRANSACTION_TYPE, STAN, etc.).
+			    final Object[] commonFields = buildCommonVoidAuthRequestFields();
+
+			    flow.update( CPC, rq( commonFields ), rs( STATUS, APPROVED ) );
+			    flow.update( CONNECTIVITY, rq( commonFields ), rs( STATUS, APPROVED ) );
+
+			    // Apply associated authorization field mapping from the base auth flow.
+			    applyAssociateFields( flow, scenario );
+
+			    // Apply void-specific scenario customizations (from VoidScenarios enum).
+			    scenario.data.accept( flow );
+		    } );
+	}
+
+	/**
+	 * Safely applies associated authorization field mapping from the cached base auth flow into the
+	 * void flow request. Uses copyFieldFromDependency to extract auth response fields and map them
+	 * into void {@code ASSOCIATED_AUTHORIZATION_*} request fields. Implements null-safety: if the
+	 * auth flow is not found in {@link #flowMap}, logs a warning and gracefully skips field mapping.
+	 *
+	 * @param voidFlow the void flow to apply field mappings to
+	 * @param scenario the void scenario providing context for field mapping
+	 */
+	private void applyAssociateFields( Deriver voidFlow, VoidScenarios scenario ) {
+		Flow authFlow = flowMap.get( scenario );
+
+		if ( authFlow == null ) {
+			// Log warning and gracefully skip field mapping if auth flow not found.
+			System.err.println( "WARNING: Auth flow not found for scenario " + scenario.name()
+			    + "; skipping associated field mapping for void flow." );
+			return;
+		}
+
+		// Safely copy key transaction fields from auth response to void request.
+		// These fields establish the relationship between the void and its associated auth.
+		// Each field copy is in its own try-catch to handle optional fields gracefully.
+
+		try {
+			// Copy network transaction ID from auth response to void request.
+			copyFieldFromDependency(
+			    authFlow,
+			    RESPONSE, REQUEST,
+			    SERVICEPROVIDER_TRANSACTIONPROCESSING_NETWORKTRANSACTIONID,
+			    ASSOCIATED_AUTHORIZATION_TRANSACTION_ID ).accept( voidFlow );
+		}
+		catch ( Exception e ) {
+			// Log at WARN level for missing/optional fields; do not fail the flow.
+			System.err.println( "WARNING: Error mapping network transaction ID for scenario "
+			    + scenario.name() + ": " + e.getMessage() );
+		}
+
+		try {
+			// Copy linked transaction ID from auth response to void request (optional).
+			copyFieldFromDependency(
+			    authFlow,
+			    RESPONSE, REQUEST,
+			    SERVICEPROVIDER_TRANSACTIONPROCESSING_NETWORKTRANSACTIONID,
+			    ASSOCIATED_AUTHORIZATION_NETWORK_TRANSACTION_ID ).accept( voidFlow );
+		}
+		catch ( Exception e ) {
+			// Log at WARN level for missing/optional fields; do not fail the flow.
+			System.err.println( "WARNING: Linked transaction ID not available for scenario "
+			    + scenario.name() + " (optional field)" );
+		}
+	}
+
+	/**
+	 * Composes CPC/CONNECTIVITY delta request fields from focused section helpers. Only values that
+	 * differ from the base flow are included.
+	 *
+	 * @return alternating field-name/value pairs for use in {@code rq(...)}
+	 */
+
+	private Object[] buildCommonVoidAuthRequestFields() {
+		return Stream.of(
+		    buildSubmissionFields(),
+		    buildCoreTransactionFields(),
+		    buildCardTypeFields(),
+		    buildPaymentInstrumentFields(),
+		    buildMerchantFields() ).flatMap( Arrays::stream ).toArray();
+	}
+
+	/** @return top-level void submission fields. */
+	private Object[] buildSubmissionFields() {
+		return new Object[]{
+		    SYSTEM_TRACE_AUDIT_NUMBER, ACQ_VOID_STAN,
+		    TRANSACTION_TYPE, TXN_TYPE_VOID_AUTH
+		};
+	}
+
+	/** @return associatedAuthorization core transaction-identity fields. */
+	private Object[] buildCoreTransactionFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_RETRIEVAL_REFERENCE_NUMBER, ACQ_VOID_RRN,
+		    ASSOCIATED_AUTHORIZATION_SYSTEM_TRACE_AUDIT_NUMBER, STAN_VALUE,
+		    ASSOCIATED_AUTHORIZATION_AUTHORIZED_AMOUNT, VOID_AUTH_AUTHORIZED_AMOUNT,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_ID, AUTH_NETWORK_TRANSACTION_ID,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_TYPE, TXN_TYPE_AUTHORIZATION,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_CURRENCY, AUTH_CURRENCY,
+		    ASSOCIATED_AUTHORIZATION_LINKED_TRANSACTION_ID, AUTH_NETWORK_TRANSACTION_ID,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_SOURCE, PAYMENT_SOURCE_MOTO,
+		    ASSOCIATED_AUTHORIZATION_SERVICE_PROVIDER_TRANSACTION_ID,
+		    VOID_SERVICE_PROVIDER_TRANSACTION_ID,
+		    ASSOC_AUTH_SUBMISSION_TIMESTAMP, DEFAULT_SUBMISSION_TIMESTAMP
+		};
+	}
+
+	/** @return associatedAuthorization cardType fields. */
+	private Object[] buildCardTypeFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_CARD_TYPE_SCHEME, SCHEME_MASTERCARD,
+		    ASSOCIATED_AUTHORIZATION_CARD_TYPE_FUNDING_METHOD, FUNDING_DEBIT
+		};
+	}
+
+	/** @return associatedAuthorization paymentInstrument fields. */
+	private Object[] buildPaymentInstrumentFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_NUMBER, MC_PAN,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_EXPIRY_MONTH, CARD_EXPIRY_MONTH,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_EXPIRY_YEAR, CARD_EXPIRY_YEAR
+		};
+	}
+
+	/** @return associatedAuthorization merchant fields. */
+	private Object[] buildMerchantFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_ACQUIRER_MERCHANT_ID, VOID_MERCHANT_ACQUIRER_ID,
+		    ASSOC_AUTH_MERCHANT_CATEGORY_CODE, VOID_MERCHANT_CATEGORY_CODE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_TIME_ZONE, VOID_MERCHANT_TIME_ZONE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_CITY, MERCHANT_CITY,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_COUNTRY, VOID_MERCHANT_COUNTRY,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_LINE1, VOID_MERCHANT_LINE1,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_POSTAL_CODE, VOID_MERCHANT_POSTAL_CODE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_ORDER_REFERENCE, DEFAULT_MERCHANT_ORDER_REF,
+		    ASSOCIATED_AUTHORIZATION_POINT_OF_SERVICE_TERMINAL_ID, DEFAULT_TERMINAL_ID,
+		    ASSOCIATED_AUTHORIZATION_SYSTEM_TRACE_AUDIT_NUMBER, STAN_VALUE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_NAME, MERCHANT_NAME_VALUE,
+		    ASSOCIATED_AUTHORIZATION_RETRIEVAL_REFERENCE_NUMBER, ACQ_VOID_RRN
+		};
+	}
+}
