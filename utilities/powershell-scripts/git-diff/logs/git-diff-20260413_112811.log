+/**
+ * VOID_AUTH flows for the Elavon Flow Test Framework, derived from
+ * {@code authVoid.authVoid_With_All_Fields}. // Migrated from: Void.transactions() ΓÇö PAY, CAPTURE,
+ * REFUND, UPDATE_AUTH, TSPI excluded per rules v3.0.
+ */
+public final class ElavonVoidTransactions extends EagerModel {
+
+	public static final String VOID_TAG = "authVoid";
+
+	public static final TaggedGroup MODEL_TAGS = new TaggedGroup( VOID_TAG );
+
+	// Matches ISO 8583 amount "000000002112" (21.12 in minor units).
+	private static final BigDecimal VOID_AUTH_AUTHORIZED_AMOUNT = new BigDecimal( "21.12" );
+
+	private final AuthFPAN authFPAN = new AuthFPAN();
+	private final AuthVoid authVoid = new AuthVoid( authFPAN );
+
+	public ElavonVoidTransactions() {
+		super( MODEL_TAGS );
+
+		final Stream<Flow> voidFlows = Arrays.stream( VoidScenarios.values() )
+		    .map( this::createVoidAuthFlow );
+
+		members( flatten( voidFlows ) );
+	}
+
+	/**
+	 * Builds a VOID_AUTH flow deriving from {@code authVoid.authVoid_With_All_Fields}, which already
+	 * carries all {@code associatedAuthorization.*} fields.
+	 *
+	 * @param scenario the void scenario to build
+	 * @return the built {@link Flow}
+	 */
+	private Flow createVoidAuthFlow( VoidScenarios scenario ) {
+		return Deriver.build( authVoid.authVoid_With_All_Fields, getElavonVoidBaseInteraction(),
+		    flow -> {
+			    flow.meta( data -> data
+			        .trace( scenario.getDescription() )
+			        .description( scenario.getDescription() )
+			        .tags( set( VOID_TAG ) ) );
+
+			    // Mirrors WorldPay VoidAuthScenarios#buildCommonVoidAuthRequestFields().
+			    final Object[] commonFields = buildCommonVoidAuthRequestFields();
+
+			    flow.update( CPC, rq( commonFields ), rs( STATUS, APPROVED ) );
+			    flow.update( CONNECTIVITY, rq( commonFields ), rs( STATUS, APPROVED ) );
+
+			    scenario.data.accept( flow );
+		    } );
+	}
+
+	/**
+	 * Composes CPC/CONNECTIVITY delta request fields from focused section helpers. Only values that
+	 * differ from the base flow are included.
+	 *
+	 * @return alternating field-name/value pairs for use in {@code rq(...)}
+	 */
+	private Object[] buildCommonVoidAuthRequestFields() {
+		return Stream.of(
+		    buildSubmissionFields(),
+		    buildCoreTransactionFields(),
+		    buildCardTypeFields(),
+		    buildPaymentInstrumentFields(),
+		    buildMerchantFields() ).flatMap( Arrays::stream ).toArray();
+	}
+
+	/** @return top-level void submission fields. */
+	private Object[] buildSubmissionFields() {
+		return new Object[]{
+		    SYSTEM_TRACE_AUDIT_NUMBER, ACQ_VOID_STAN,
+		    TRANSACTION_TYPE, TXN_TYPE_VOID_AUTH
+		};
+	}
+
+	/** @return associatedAuthorization core transaction-identity fields. */
+	private Object[] buildCoreTransactionFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_RETRIEVAL_REFERENCE_NUMBER, ACQ_VOID_RRN,
+		    ASSOCIATED_AUTHORIZATION_SYSTEM_TRACE_AUDIT_NUMBER, STAN_VALUE,
+		    ASSOCIATED_AUTHORIZATION_AUTHORIZED_AMOUNT, VOID_AUTH_AUTHORIZED_AMOUNT,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_ID, AUTH_NETWORK_TRANSACTION_ID,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_TYPE, TXN_TYPE_AUTHORIZATION,
+		    ASSOCIATED_AUTHORIZATION_TRANSACTION_CURRENCY, AUTH_CURRENCY,
+		    ASSOCIATED_AUTHORIZATION_LINKED_TRANSACTION_ID, AUTH_NETWORK_TRANSACTION_ID,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_SOURCE, PAYMENT_SOURCE_MOTO,
+		    ASSOCIATED_AUTHORIZATION_SERVICE_PROVIDER_TRANSACTION_ID,
+		    VOID_SERVICE_PROVIDER_TRANSACTION_ID,
+		    ASSOC_AUTH_SUBMISSION_TIMESTAMP, DEFAULT_SUBMISSION_TIMESTAMP
+		};
+	}
+
+	/** @return associatedAuthorization cardType fields. */
+	private Object[] buildCardTypeFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_CARD_TYPE_SCHEME, SCHEME_MASTERCARD,
+		    ASSOCIATED_AUTHORIZATION_CARD_TYPE_FUNDING_METHOD, FUNDING_DEBIT
+		};
+	}
+
+	/** @return associatedAuthorization paymentInstrument fields. */
+	private Object[] buildPaymentInstrumentFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_NUMBER, MC_PAN,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_EXPIRY_MONTH, CARD_EXPIRY_MONTH,
+		    ASSOCIATED_AUTHORIZATION_PAYMENT_INSTRUMENT_CARD_EXPIRY_YEAR, CARD_EXPIRY_YEAR
+		};
+	}
+
+	/** @return associatedAuthorization merchant fields. */
+	private Object[] buildMerchantFields() {
+		return new Object[]{
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_ACQUIRER_MERCHANT_ID, VOID_MERCHANT_ACQUIRER_ID,
+		    ASSOC_AUTH_MERCHANT_CATEGORY_CODE, VOID_MERCHANT_CATEGORY_CODE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_TIME_ZONE, VOID_MERCHANT_TIME_ZONE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_CITY, MERCHANT_CITY,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_COUNTRY, VOID_MERCHANT_COUNTRY,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_LINE1, VOID_MERCHANT_LINE1,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_POSTAL_CODE, VOID_MERCHANT_POSTAL_CODE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_ORDER_REFERENCE, DEFAULT_MERCHANT_ORDER_REF,
+		    ASSOCIATED_AUTHORIZATION_POINT_OF_SERVICE_TERMINAL_ID, DEFAULT_TERMINAL_ID,
+		    ASSOCIATED_AUTHORIZATION_SYSTEM_TRACE_AUDIT_NUMBER, STAN_VALUE,
+		    ASSOCIATED_AUTHORIZATION_MERCHANT_NAME, MERCHANT_NAME_VALUE,
+		    ASSOCIATED_AUTHORIZATION_RETRIEVAL_REFERENCE_NUMBER, ACQ_VOID_RRN
+		};
+	}
+}
