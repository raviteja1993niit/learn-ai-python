+@echo off
+:: Simple wrapper to run generate-tree.ps1 from project root.
+:: Usage: run-generate-tree.bat [MaxDepth] [OutFile]
+
+set "SCRIPT_DIR=%~dp0"
+set "PS_SCRIPT=%SCRIPT_DIR%generate-tree.ps1"
+
+set "MAXDEPTH=%~1"
+set "OUTFILE=%~2"
+
+if "%OUTFILE%"=="" (
+  set "OUTFILE=%CD%\project-tree.txt"
+)
+
+if not "%MAXDEPTH%"=="" (
+  set "MAXDEPTH_ARG=-MaxDepth %MAXDEPTH%"
+) else (
+  set "MAXDEPTH_ARG="
+)
+
+echo Running: powershell -NoProfile -ExecutionPolicy Bypass -File "%PS_SCRIPT%" -TargetPath "%CD%" %MAXDEPTH_ARG% -OutFile "%OUTFILE%"
+powershell -NoProfile -ExecutionPolicy Bypass -File "%PS_SCRIPT%" -TargetPath "%CD%" %MAXDEPTH_ARG% -OutFile "%OUTFILE%"
+
+:: Note: Do not pass OutFile with escaped surrounding quotes (e.g. \"C:\path\file.txt\").
+:: Pass a normal path (relative or absolute) as the second argument.

